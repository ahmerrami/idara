# Target path on the host machine where compose/env/media will live
DEPLOY_PATH=/opt/idara

# Docker image settings
DOCKERHUB_USERNAME=your-dockerhub-username
TAG=latest

# Django production settings
DJANGO_SECRET_KEY=change-me-very-long-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_DB_SSL_REQUIRE=false
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=
SOCIETE=Idara
BLOCKED_IPS=

AUTHEMAIL_EMAIL_HOST=
AUTHEMAIL_EMAIL_PORT=587
AUTHEMAIL_EMAIL_HOST_USER=
AUTHEMAIL_EMAIL_HOST_PASSWORD=
AUTHEMAIL_EMAIL_SUBJECT_PREFIX=[Idara]
AUTHEMAIL_EMAIL_VERIFICATION_URL=/api/accounts/email/verify/
AUTHEMAIL_PASSWORD_RESET_URL=/accounts/password/reset/confirm/

# PostgreSQL container settings
POSTGRES_DB=idara
POSTGRES_USER=idara
POSTGRES_PASSWORD=change-me
POSTGRES_VOLUME_NAME=idara_prod_postgres_data

# App database URL used by Django
DATABASE_URL=postgresql://idara:change-me@db:5432/idara
